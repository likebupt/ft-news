# ============================================================
# FT News Weekly - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# --- Azure OpenAI (for summarization) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Microsoft Teams Incoming Webhook ---
# Create a webhook in your Teams channel:
# Channel Settings > Connectors > Incoming Webhook > Configure
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/xxx

# --- Data Storage ---
# Directory to store daily/weekly summaries (relative or absolute)
DATA_DIR=data

# --- Schedule ---
# Daily fetch time (24h format, PST)
DAILY_FETCH_HOUR=18
DAILY_FETCH_MINUTE=0

# Weekly digest + push time (24h format, PST)
WEEKLY_PUSH_HOUR=9
WEEKLY_PUSH_MINUTE=0

# --- Optional ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

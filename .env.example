# ============================================================
# FT News Weekly - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# --- Azure AI Foundry / Azure OpenAI (for summarization) ---
# For Foundry: use the base URL from your deployment's Target URI,
#   e.g. https://my-resource.services.ai.azure.com/
# For classic Azure OpenAI: https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-pro
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# --- Email via Azure Logic App HTTP trigger ---
# Create a Logic App with an HTTP request trigger and an Office 365 Outlook send email action.
# Use the full HTTP POST URL, including its SAS token query string.
LOGIC_APP_URL=https://prod-00.region.logic.azure.com/workflows/.../triggers/manual/paths/invoke?api-version=2016-10-01&sp=...&sv=...&sig=...
# Optional sender metadata if your Logic App workflow expects it.
EMAIL_SENDER=you@microsoft.com
# Semicolon-separated list of recipients
EMAIL_RECIPIENTS=you@microsoft.com;teammate@microsoft.com

# --- Data Storage ---
# Directory to store daily/weekly summaries (relative or absolute)
DATA_DIR=data

# --- Schedule ---
# Daily fetch time (24h format, PST)
DAILY_FETCH_HOUR=18
DAILY_FETCH_MINUTE=0

# Weekly digest + push time (24h format, PST)
WEEKLY_PUSH_HOUR=9
WEEKLY_PUSH_MINUTE=0

# --- Optional ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
